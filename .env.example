RUNTIME_PROFILE=desktop
DATABASE_URL=sqlite:///./artifacts/dev/opc-dev.db
# Self-hosted PostgreSQL alternative:
# RUNTIME_PROFILE=self_hosted
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/opc
DATABASE_CONNECT_TIMEOUT_SECONDS=2
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_REQUIRED=true
EMBEDDING_DIMENSIONS=1536

# ============================================================
# yunwu.ai API configuration (the only API provider)
# ============================================================
# YUNWU_API_KEY is the single API key used for both LLM and image services.
YUNWU_API_KEY=replace-with-your-yunwu-api-key
YUNWU_BASE_URL=https://yunwu.ai

# LLM (draft + review + rewrite): gpt-5.6-luna via /v1/responses
DRAFT_PROVIDER=openai_compatible
DRAFT_MODEL=gpt-5.6-luna
DRAFT_TIMEOUT_SECONDS=60
DRAFT_MAX_TOKENS=1800
DRAFT_TEMPERATURE=0.7

# Image generation: gpt-image-2 via /v1/images/generations
IMAGE_PROVIDER=openai_compatible
IMAGE_MODEL=gpt-image-2
IMAGE_SIZE=1024x1366
IMAGE_RESPONSE_FORMAT=b64_json
IMAGE_TIMEOUT_SECONDS=600

TEST_STATIC_URL_PREFIX=/static/generated

# Deprecated aliases (kept for backward compatibility; fall back to YUNWU_API_KEY):
# OPENAI_COMPATIBLE_API_KEY=replace-with-your-yunwu-api-key
OPENAI_COMPATIBLE_BASE_URL=https://yunwu.ai
# IMAGE_OPENAI_COMPATIBLE_API_KEY uses the same YUNWU_API_KEY
IMAGE_OPENAI_COMPATIBLE_BASE_URL=https://yunwu.ai

# Review (AI review) uses the same yunwu provider/model
REVIEW_PROVIDER=openai_compatible
REVIEW_MODEL=gpt-5.6-luna
REVIEW_TIMEOUT_SECONDS=60
REVIEW_MAX_TOKENS=1200
REVIEW_TEMPERATURE=0.3

# --- Deprecated providers (no longer used; yunwu.ai is the only provider) ---
# DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_REWRITE_MODEL=deepseek-v4-pro
# DEEPSEEK_TIMEOUT_SECONDS=60
# TAVILY_API_KEY=tvly-dev-your-key-here
# TAVILY_BASE_URL=https://api.tavily.com
# TAVILY_SEARCH_ENABLED=false
# TAVILY_TIMEOUT_SECONDS=25
# TAVILY_MAX_RESULTS=6

FRONTEND_ORIGIN=http://localhost:60000
# CORS_ORIGIN_REGEX=  # Optional. When unset, CORS origins are derived from FRONTEND_ORIGIN (plus localhost/private IP defaults).

# Knowledge compilation settings
KNOWLEDGE_COMPILE_ENABLED=true
KNOWLEDGE_COMPILE_INTERVAL_HOURS=168
KNOWLEDGE_COMPILE_CHECK_INTERVAL_SECONDS=3600
KNOWLEDGE_COMPILE_SOURCE_LIMIT=120

# Additional configuration
ZSCJ_API_BASE_URL=http://localhost:60002/api/v1

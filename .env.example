DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/opc
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
EMBEDDING_DIMENSIONS=1536
DRAFT_PROVIDER=codex_test
DRAFT_MODEL=gpt-5.5
DRAFT_TIMEOUT_SECONDS=120
IMAGE_PROVIDER=codex_test
TEST_STATIC_URL_PREFIX=/static/generated
OPENAI_COMPATIBLE_API_KEY=replace-with-your-openai-compatible-api-key
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_REWRITE_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT_SECONDS=60
FRONTEND_ORIGIN=http://localhost:3000
